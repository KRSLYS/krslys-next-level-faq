  "apiVersion": 3,
  "name": "krslys-next-level/accordion",
  "title": "Next Level Accordion",
  "category": "widgets",
  "icon": "list-view",
  "description": "Display a styled accordion section with collapsible content panels.",
  "keywords": ["accordion", "collapse", "toggle", "sections"],
  "textdomain": "krslys-next-level-faq-accordion",
  "supports": {
    "html": false,
    "align": true,
    "anchor": true
  },
  "attributes": {
    "groupId": {
