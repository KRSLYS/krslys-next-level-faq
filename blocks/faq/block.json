{
  "$schema": "https://schemas.wp.org/trunk/block.json",
  "apiVersion": 3,
  "name": "krslys-next-level/faq",
  "title": "Next Level FAQ",
  "category": "widgets",
  "icon": "editor-help",
  "description": "Display a styled FAQ section using the Next Level FAQ styles.",
  "keywords": ["faq", "accordion", "help"],
  "textdomain": "krslys-next-level-faq-accordion",
  "supports": {
    "html": false,
    "align": true,
    "anchor": true
  },
  "attributes": {
    "groupId": {
      "type": "number",
      "default": 0
    },
    "preset": {
      "type": "string",
      "default": ""
    }
  },
  "editorScript": "nlf-faq-block-editor",
  "style": "nlf-faq-generated"
}


